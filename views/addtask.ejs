<%- include('partials/head') %>
    <body>
        <%- include('partials/header') %>
            <div class="form-container">
                <div class="page-header">
                    <h1 style="margin:0;">Add New Task</h1>
                    <a href="/api/" class="add-btn" style="background:#6c757d;">Back</a>
                </div>

                <% if(typeof error !== 'undefined' && error ) { %>
                    <div style="background:#f8d7da;color:#721c24;padding:10px;border-radius:5px;margin-bottom:15px;">
                        <% error.split(', ').forEach(err => { %>
                            <li><%= err %></li>
                        <% }); %>
                    </div>
                <% } %>

                <form action="/api/tasks<%= task && task.id ? '/' + task.id + '?_method=PUT' : '' %>" method="POST" enctype="multipart/form-data">

                    <input type="hidden" name="_token" value="<%= token %>">
                       <!-- For edit: add task ID -->
                    <% if (task && task.id) { %>
                        <input type="hidden" name="id" value="<%= task.id %>">
                    <% } %>
                    <div class="form-group">
                        <label>Task Name</label>
                        <input type="text" name="title" value="<%= task && task.title ? task.title : '' %>" placeholder="Enter task name">
                    </div>

                    <div class="form-group">
                        <label>Description</label>
                        <textarea rows="3" name="description" placeholder="Enter description"><%= task.description%></textarea>
                    </div>

                    <div class="row">
                        <div class="form-group">
                            <label>Priority</label>
                            <select name="priority" class="form-control">
                                <% const prioritys=['low', 'medium', 'high' ]; %>
                                <% prioritys.forEach(pr=> { %>
                                    <option value="<%= pr %>" <%=task.priority===pr ? 'selected' : '' %>><%= pr %>
                                    </option>
                                    <% }); %>
                            </select>
                       </div>
                        <div class="form-group">
                            <label>Status</label>
                            <select name="status" class="form-control">
                                <% const statuses=['pending', 'in-progress' , 'completed' ]; %>
                                <% statuses.forEach(st => { %>
                                    <option value="<%= st %>" <%=task.status===st ? 'selected' : '' %>><%= st %>
                                    </option>
                                <% }); %>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Assign To</label>
                        <input type="email" name="assignTo" value="<%= task && task.assignTo ? task.assignTo : '' %>"
                            placeholder="Enter user email">
                    </div>


                    <div class="form-group">
                        <label>Due Date</label>
                        <input name="due_date"  value="<%= task.due_date ? task.due_date : '' %>" type="date">
                    </div>

                    <!-- <% if (task && task.id) { %>
                    <div class="form-group">
                        <label>Product Image</label>
                        <input type="file" name="attachments" class="form-control">
                        <% if (task.attachments) { %>
                            <small>Current: <%= task.attachments.split('/').pop() %></small>
                            <% } %>
                    
                    </div>
                    <% } %> -->

                    <div class="actions">
                        <!-- <button class="btn cancel">Cancel</button>
                        <button class="btn save">Save Task</button> -->
                        <a href="/api/tasks" class="btn cancel">Cancel</a>
                        <button type="submit" class="btn save" id="saveBtn">Save Task</button>

                    </div>

                </form>

                <!-- ADD upload section here -->
                <% if (task && task.id) { %>
                    <div style="margin-top:20px; padding-top:20px; border-top:1px solid #ddd;">
                        <h3>Upload Attachment</h3>
                        <form action="/api/tasks/<%= task.id %>/upload" method="POST" enctype="multipart/form-data">
                            <div class="form-group">
                                <input type="file" name="attachments" class="form-control" accept=".jpg,.png,.gif,.webp,.pdf">
                                <small>Max 5MB. Allowed: JPG, PNG, GIF, WEBP, PDF</small>
                            </div>
                            <% if (task.attachments) { %>
                                <p>Current: <%= task.attachments.split('/').pop() %>
                                </p>
                                <img src="/<%= task.attachments %>" alt="" style="max-width:200px;">
                                <% } %>
                                    <button type="submit" class="btn save">Upload</button>
                        </form>
                    </div>
                    <% } %>


            </div>

    </body>

    </html>
